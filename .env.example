# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Crypto Swing Trader
DEBUG=false
PORT=8001

# ── Database (same PostgreSQL as AI Data Copilot) ────────────────────────────
# Local: postgresql://arout@localhost:5432/copilot_db
# EC2:   postgresql://copilot:copilot@localhost:5432/copilot_db
DATABASE_URL=postgresql://arout@localhost:5432/copilot_db

# ── Trading config ────────────────────────────────────────────────────────────
SYMBOLS=BTC/USDT,ETH/USDT
TIMEFRAMES=15m,1h
TOTAL_CAPITAL=100000.0
RISK_PER_TRADE_PCT=2.0
STOP_LOSS_PCT=2.0
TARGET_PCT=4.0
CANDLES_LIMIT=200
SCHEDULE_INTERVAL_MINUTES=10

# ── Binance API (optional — only for live trading, not needed for signals) ───
# BINANCE_API_KEY=your_key
# BINANCE_SECRET=your_secret

# ── AI Filter ─────────────────────────────────────────────────────────────────
# Options: groq | openai | disabled
AI_PROVIDER=groq
AI_CONFIDENCE_THRESHOLD=70

# Groq (free, fast) — get key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# OpenAI (optional)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ── Email alerts (Gmail) ─────────────────────────────────────────────────────
EMAIL_ENABLED=false
# SMTP_USER=youremail@gmail.com
# SMTP_PASSWORD=your_app_password   # Gmail App Password (not account password)
# ALERT_EMAIL_TO=recipient@example.com

# ── WhatsApp alerts (Twilio) ──────────────────────────────────────────────────
WHATSAPP_ENABLED=false
# TWILIO_ACCOUNT_SID=ACxxxxxx
# TWILIO_AUTH_TOKEN=your_token
# TWILIO_FROM=whatsapp:+14155238886
# TWILIO_TO=whatsapp:+91XXXXXXXXXX
